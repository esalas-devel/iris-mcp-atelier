# InterSystems IRIS connection settings
# Copy this file to `.env` and edit the values.

# Base URL of your IRIS server (no trailing slash)
IRIS_SERVER_URL=http://127.0.0.1:80

# Credentials for an account with permission to use the Atelier REST API
IRIS_USERNAME=_SYSTEM
IRIS_PASSWORD=SYS

# Default namespace used when a tool call does not specify one
IRIS_DEFAULT_NAMESPACE=USER

# Request timeout in milliseconds (optional, defaults to 30000)
IRIS_TIMEOUT=30000
